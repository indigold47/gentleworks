# Sanity — create the project at https://sanity.io/manage (or run
# `npx sanity@latest init` once, letting it write these values for you) then
# copy this file to `.env.local` and fill in the real values.

# Shipped to the browser — required by the embedded Studio at /studio.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Optional. Defaults to the pinned date in sanity/env.ts. Bump when you add
# schema or features that depend on newer GROQ behavior.
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-09

# Server-only. Create a read token at sanity.io/manage → API → Tokens with
# Viewer permission. Leave empty if you only need published content.
SANITY_API_READ_TOKEN=

# Server-only. Shared secret used to verify /api/revalidate calls from the
# Sanity webhook. Generate one with: `openssl rand -hex 32`.
SANITY_REVALIDATE_SECRET=
